# Binomo
BINOMO_EMAIL=
BINOMO_PASSWORD=

# Modo de operação: discovery | trade | backtest
MODE=discovery

# Armazenamento persistente da sessão (login salvo)
USER_DATA_DIR=.binomo-profile

# Tempo de expiração padrão (segundos): 30,60,120,180,300
EXPIRATION_SECONDS=60

# Timeframe do candle em segundos (a Binomo envia ticks; o bot agrega em candles)
# 5 = candle de 5s (mais ruído), 15 = 15s (recomendado), 60 = 1min (conservador)
CANDLE_TIMEFRAME_SECONDS=15

# Valor padrão da entrada (demo)
ENTRY_VALUE=5

# Ativo padrão (RIC como aparece no WebSocket, ex: Z-CRY/IDX)
ASSET=Z-CRY/IDX

# Risk management
MAX_DAILY_TRADES=20
MAX_DAILY_LOSS=100
# Martingale (Gale): apos LOSS, proxima entrada é multiplicada
# CUIDADO: martingale alto pode quebrar a banca. Recomendado: 0 ou no max 2 niveis.
# Gale 0: R$5 | Gale 1: R$10 | Gale 2: R$20 (com 2.0x)
# Niveis altos (5x com 2.3x) = R$321 na ultima tentativa — PERIGOSO!
MARTINGALE_LEVELS=0
MARTINGALE_MULTIPLIER=2.0
COOLDOWN_SECONDS=15
# Score mínimo (0-100). 80 = muito seletivo (poucos trades, alta qualidade).
# 70 = balanceado. 60 = agressivo (mais trades, mais ruído).
MIN_SIGNAL_SCORE=80

# Filtro de horário de trading:
#   forex     = só opera em sessões de Londres/NY (7-16 UTC) — para pares forex
#   synthetic = 24/7 (para ativos sintéticos como Z-CRY/IDX)
#   custom    = usa SESSION_START_HOUR / SESSION_END_HOUR (UTC)
#   always    = sempre (sem filtro)
SESSION_FILTER=synthetic
SESSION_START_HOUR=7
SESSION_END_HOUR=16

# Gravar candles em CSV para backtest posterior
RECORD_CANDLES=true

# Tempo entre ciclos de análise (ms)
POLL_INTERVAL_MS=1000

# Headless (false para ver o navegador)
HEADLESS=false

# === Cérebro IA (filtro de validação) ===
# Ativar validação de sinais por IA (true/false)
AI_ENABLED=false

# Endpoint OpenAI-compatible. Opções gratuitas:
#   Groq (grátis, rápido):  https://api.groq.com/openai/v1
#   Gemini (grátis):        https://generativelanguage.googleapis.com/v1beta/openai
#   DeepSeek (barato):      https://api.deepseek.com
#   Ollama local (grátis):  http://localhost:11434/v1
AI_ENDPOINT=https://api.groq.com/openai/v1

# Chave da API (vazia se usar Ollama local)
# Groq: crie em https://console.groq.com/keys (grátis)
AI_API_KEY=

# Modelo (depende do endpoint):
#   Groq:    llama-3.3-70b-versatile  (recomendado, grátis)
#   Gemini:  gemini-1.5-flash
#   DeepSeek: deepseek-chat
#   Ollama:  llama3.2
AI_MODEL=llama-3.3-70b-versatile

# Confiança mínima da IA para aprovar sinal (0-100)
AI_MIN_CONFIDENCE=60

# Timeout da chamada à IA (ms)
AI_TIMEOUT_MS=10000
